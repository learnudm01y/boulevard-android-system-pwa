<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows cleartext HTTP to the development server.
  10.0.2.2  = Android emulator alias for the host machine's localhost
  10.0.3.2  = Genymotion emulator alias
  192.168.x.x = real device on local WiFi (add your PC's IP if needed)
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
